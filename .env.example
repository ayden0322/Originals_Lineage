# Platform DB (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=platform_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=platform_db

# Game DB (MySQL - remote)
GAME_MYSQL_HOST=<remote-ip>
GAME_MYSQL_PORT=3306
GAME_MYSQL_USER=<user>
GAME_MYSQL_PASSWORD=<secret>
GAME_MYSQL_DB=endless_paradise

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Password Encryption (AES-256-GCM, 32 bytes hex = 64 hex chars)
# 產生新金鑰：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 用途：對官網密碼做可還原加密，以便遊戲庫清空後能還原
PASSWORD_ENC_KEY=change-this-to-a-64-char-hex-string

# MinIO (Object Storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=originals-uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# App
BACKEND_PORT=4000
FRONTEND_PORT=3000
NODE_ENV=development
